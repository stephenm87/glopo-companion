# Glopo Companion — Environment Variables
# Copy this file to .env and fill in your values for local development.
# Production values are set in the Netlify dashboard under Site > Environment Variables.

# ── Gemini AI (required for Writing Studio AI features) ──────────────────────
# Used by all Netlify functions (analyze-essay, peel-review, find-cases, generate-intro)
GEMINI_API_KEY=your_gemini_api_key_here

# Used by the React frontend for local dev fallbacks (when Netlify functions are not running)
# Double prefix: REACT_APP_ is read by Create React App; VITE_ equivalent is VITE_GEMINI_API_KEY
REACT_APP_GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Cloud NL API (optional — enhances essay feedback with AO insights) ─
# Used by analyze-essay.js to extract entities + sentiment from submitted essays.
# Falls back to GEMINI_API_KEY if not set (same GCP project key works for NL API).
GOOGLE_NL_API_KEY=your_google_cloud_api_key_here

# ── Vertex AI / Semantic Search (optional) ────────────────────────────────────
# Used by semantic-search.js for embedding-based case matching.
VERTEX_AI_PROJECT=your_gcp_project_id
VERTEX_AI_LOCATION=us-central1

# ── Speech-to-Text (optional) ─────────────────────────────────────────────────
# Used by analyze-image-essay.js for voice input features.
GOOGLE_SPEECH_API_KEY=your_google_cloud_api_key_here
